# ══════════════════════════════════════════════════════════════
#  ASTRA — Environment Configuration Template
#  Copy to `.env` and fill in real values. Never commit `.env`.
#
#  F-010: every variable any code path reads is listed here, grouped
#  by subsystem. Lines tagged `[REQUIRED-PROD]` MUST be set in
#  production — `enforce_production_guards()` in app/config.py
#  refuses to start without them. Lines tagged `[OPTIONAL]` can stay
#  empty in dev (the relevant feature degrades gracefully).
# ══════════════════════════════════════════════════════════════


# ── Database ──
# [REQUIRED-PROD] DATABASE_URL is the only authoritative connection
# string. The POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB trio is
# read by docker-compose to bootstrap the postgres container; the
# backend connects via DATABASE_URL.
POSTGRES_USER=astra
POSTGRES_PASSWORD=astra_dev_password_change_me
POSTGRES_DB=astra
DATABASE_URL=postgresql://astra:astra_dev_password_change_me@db:5432/astra


# ── pgAdmin (dev only) ──
PGADMIN_DEFAULT_EMAIL=admin@astra.local
PGADMIN_DEFAULT_PASSWORD=pgadmin_change_me


# ── Auth / JWT ──
# [REQUIRED-PROD] SECRET_KEY signs JWTs. Must be 64 hex chars
# (`openssl rand -hex 32`). The dev placeholder triggers a startup
# refusal in production via `enforce_production_guards()`.
SECRET_KEY=replace-with-64-char-random-string-openssl-rand-hex-32
ALGORITHM=HS256
# F-068: 30-min access TTL, paired with refresh-token rotation
# (see /auth/refresh). Pre-fix this was 480 (8 hours) and a stolen
# token owned the session for the rest of the work day.
ACCESS_TOKEN_EXPIRE_MINUTES=30


# ── Encryption at rest (NIST SC-28) ──
# [REQUIRED-PROD] Fernet key used for field-level encryption of
# integration_configs.config_encrypted, mfa_configs.secret_encrypted,
# etc. Must be 64 hex chars (32 bytes). Empty string disables — fine
# for dev, NOT fine for prod (startup guard refuses).
ENCRYPTION_KEY=
# Optional salt for key derivation when rotating ENCRYPTION_KEY.
ENCRYPTION_KEY_SALT=
# [OPTIONAL] When `true`, the encryption layer accepts and re-encrypts
# legacy plaintext values during read. Use only during a rotation
# window; leave unset in normal operation.
ALLOW_PLAINTEXT_LEGACY=


# ── TLS (used by uvicorn directly when nginx is not fronting) ──
SSL_CERT_FILE=
SSL_KEY_FILE=


# ── CORS / hosts ──
BACKEND_CORS_ORIGINS=http://localhost:3000
# [REQUIRED-PROD] In prod set to the actual host(s); '*' is rejected
# by enforce_production_guards.
ALLOWED_HOSTS=*


# ── Account lockout (NIST AC-7, F-016) ──
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30


# ── Rate limiting (NIST SC-5) ──
# F-064: these are PER-WORKER limits. With `--workers N` the effective
# per-IP ceiling is N × the value here (the buckets are process-local).
# Account lockout (above) is unaffected — its counter is in the DB.
# See SECURITY.md §4 for the full discussion.
RATE_LIMIT_DEFAULT=100
RATE_LIMIT_AUTH=10
RATE_LIMIT_IMPORT=5


# ── File upload limits (F-018) ──
# BodySizeLimitMiddleware rejects requests with Content-Length above
# MAX_UPLOAD_BYTES with HTTP 413 BEFORE the route handler reads.
MAX_UPLOAD_BYTES=52428800
MAX_UPLOAD_ROWS=50000
MAX_UPLOAD_SHEETS=25


# ── App identity ──
ENVIRONMENT=development
APP_NAME=ASTRA
APP_VERSION=1.0.0


# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1


# ══════════════════════════════════════════════════════════════
#  Optional integrations — leave empty to disable
# ══════════════════════════════════════════════════════════════

# ── AI (LLM analysis) ──
# Supported providers: openai, anthropic, local
AI_PROVIDER=
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=
AI_MAX_TOKENS=2048
AI_TIMEOUT=30


# ── Embeddings (semantic similarity / duplicate detection) ──
# Supported providers: openai, local
# `local` uses sentence-transformers (requires the optional pip extra).
# `openai` uses text-embedding-3-small (reuses AI_API_KEY above).
EMBEDDING_PROVIDER=
EMBEDDING_MODEL=


# ── Auth provider switch ──
# Default `local` (username + password). Other values: saml, oidc, piv.
# AUTH_MFA_REQUIRED forces TOTP after primary auth regardless of the
# user's per-account MFA setting.
AUTH_PROVIDER=local
AUTH_MFA_REQUIRED=false


# ── SAML 2.0 (when AUTH_PROVIDER=saml) ──
SAML_IDP_METADATA_URL=
SAML_SP_ENTITY_ID=
SAML_SP_ACS_URL=
# [REQUIRED-IF-SAML] paths to PEM-encoded SP cert + key. F-082 ensures
# both are read inside `with open(...) as f:` so a mid-read exception
# doesn't leak the file handle.
SAML_CERT_FILE=
SAML_KEY_FILE=


# ── OIDC (when AUTH_PROVIDER=oidc) ──
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=


# ── PIV / CAC (when AUTH_PROVIDER=piv) ──
# Path to the trust bundle that issued the smart-card certs. The
# nginx layer needs the CA bundle separately (see nginx.conf
# ssl_client_certificate).
PIV_CA_BUNDLE_PATH=


# ══════════════════════════════════════════════════════════════
#  Test-suite (read by test-astra-api.ps1 — F-111)
# ══════════════════════════════════════════════════════════════
# ASTRA_TEST_USER=mason
# ASTRA_TEST_PASSWORD=your-dev-password
# ASTRA_TEST_BASE=http://localhost:8000/api/v1
