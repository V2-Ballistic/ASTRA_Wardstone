# ══════════════════════════════════════════
#  ASTRA — Systems Engineering Platform
#  Environment Configuration
# ══════════════════════════════════════════

# ── Database ──
POSTGRES_USER=astra
POSTGRES_PASSWORD=astra_dev_password_change_me
POSTGRES_DB=astra
DATABASE_URL=postgresql://astra:astra_dev_password_change_me@db:5432/astra

# ── pgAdmin ──
PGADMIN_DEFAULT_EMAIL=admin@astra.local
PGADMIN_DEFAULT_PASSWORD=pgadmin_change_me

# ── Backend ──
SECRET_KEY=replace-with-64-char-random-string-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
BACKEND_CORS_ORIGINS=http://localhost:3000

# ── Account lockout (NIST AC-7, F-016) ──
# Account is locked after MAX_LOGIN_ATTEMPTS consecutive failed logins
# and auto-unlocks after LOCKOUT_DURATION_MINUTES.
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# ── File upload limits (F-018) ──
# BodySizeLimitMiddleware rejects requests with Content-Length above
# MAX_UPLOAD_BYTES with 413 before the route handler reads.
# Workbook size caps apply per-file after parse (each file).
MAX_UPLOAD_BYTES=52428800
MAX_UPLOAD_ROWS=50000
MAX_UPLOAD_SHEETS=25

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ── Environment ──
ENVIRONMENT=development

# ── AI (optional — leave empty to disable all AI features) ──
# Supported providers: openai, anthropic, local
AI_PROVIDER=
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=
AI_MAX_TOKENS=2048
AI_TIMEOUT=30

# ── Embeddings (optional — leave empty to disable semantic analysis) ──
# Supported providers: openai, local
# "local" uses sentence-transformers (requires pip install sentence-transformers)
# "openai" uses text-embedding-3-small (requires AI_API_KEY set above)
EMBEDDING_PROVIDER=
EMBEDDING_MODEL=
